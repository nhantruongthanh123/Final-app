{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",                  /* Use modern ES Modules */
    "moduleResolution": "NodeNext",        /* Tell TS how to find modern imports */
    "rootDir": ".",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "#*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}